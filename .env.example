# Copy this file to ".env" and fill in the values from your Neo4j Aura instance.
# When you create a free Aura database, Aura shows these once and offers a
# downloadable credentials file. Paste the matching values here.
#
#   .env  is git-ignored and holds your real secret.
#   .env.example  is committed and holds no secrets (this file).

# Connection URI. For Aura it looks like:  neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://CHANGE_ME.databases.neo4j.io

# Almost always "neo4j" for Aura.
NEO4J_USERNAME=neo4j

# The generated password shown when the instance was created.
NEO4J_PASSWORD=CHANGE_ME

# Database name. Aura free uses "neo4j".
NEO4J_DATABASE=neo4j
